{
  "compilerOptions": {
    "target": "ES2022",
    "module": "es2022",
    "lib": [
      "es2022",
      "webworker"
    ],
    "moduleResolution": "bundler",
    "types": [
      "@cloudflare/workers-types"
    ],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src/**/*"
  ]
}